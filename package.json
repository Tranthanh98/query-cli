{
  "name": "query-cli",
  "version": "1.0.5",
  "description": "Terminal database client",
  "type": "module",
  "module": "src/index.tsx",
  "bin": {
    "query-cli": "src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "compile": "bun build --compile src/index.tsx --outfile dist/query-cli",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@google/genai": "^2.6.0",
    "@opentui/core": "latest",
    "@opentui/react": "^0.2.15",
    "openai": "^6.39.0",
    "postgres": "^3.4.4",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.15",
    "typescript": "^5.5.0"
  }
}
